<Window x:Class="ChatGptApi.Desktop.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="540"
        SizeToContent="Height"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Margin="0"
            Padding="26"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="44"
                            Height="44"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="14">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Style="{StaticResource IconTextStyle}"
                                       FontSize="22"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE713;" />
                        </Viewbox>
                    </Border>

                    <StackPanel Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="Settings" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="The server address is already built into this app. Only the model API key is needed here." />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,22,0,0"
                    Padding="18"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="Model API key" />
                    <PasswordBox x:Name="ProviderApiKeyBox"
                                 Margin="0,10,0,0"
                                 Height="42" />
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="The key is stored only in the current Windows profile and is not committed to git." />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="{StaticResource AccentMutedBrush}"
                    CornerRadius="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource IconTextStyle}"
                               Foreground="{StaticResource AccentBrush}"
                               Text="&#xE946;" />
                    <TextBlock Margin="10,0,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="If the provider returns quota, balance, or API key errors, the app will show a clear warning." />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource GhostButtonStyle}"
                        IsCancel="True"
                        Click="OnCancelClick"
                        Content="Cancel" />
                <Button Width="140"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnSaveClick"
                        Content="Save Settings" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
