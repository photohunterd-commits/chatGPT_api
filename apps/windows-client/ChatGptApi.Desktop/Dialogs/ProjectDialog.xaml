<Window x:Class="ChatGptApi.Desktop.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Project"
        Width="560"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F2EA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#153A29"
                   Text="New Project" />

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0">
            <TextBlock Text="Name"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <TextBox x:Name="NameTextBox"
                     Margin="0,8,0,0"
                     Height="38"
                     Padding="10,8"
                     Background="White"
                     BorderBrush="#CDA778" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0">
            <TextBlock Text="Description"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <TextBox x:Name="DescriptionTextBox"
                     Margin="0,8,0,0"
                     Height="82"
                     Padding="10,8"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="White"
                     BorderBrush="#CDA778" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0">
            <TextBlock Text="System prompt"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <TextBox x:Name="SystemPromptTextBox"
                     Margin="0,8,0,0"
                     Padding="10,8"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="White"
                     BorderBrush="#CDA778" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Margin="0,24,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="110"
                    Height="38"
                    Margin="0,0,12,0"
                    Click="OnCancelClick"
                    Content="Cancel" />
            <Button Width="130"
                    Height="38"
                    Background="#153A29"
                    Foreground="White"
                    BorderBrush="#153A29"
                    Click="OnCreateClick"
                    Content="Create Project" />
        </StackPanel>
    </Grid>
</Window>
