<Window x:Class="ChatGptApi.Desktop.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Project"
        Width="600"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Margin="0"
            Padding="26"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="44"
                            Height="44"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="14">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Style="{StaticResource IconTextStyle}"
                                       FontSize="22"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE8B7;" />
                        </Viewbox>
                    </Border>

                    <StackPanel Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="New Project" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Create a project space for a product, client, or internal stream of work." />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,22,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="Name" />
                <TextBox x:Name="NameTextBox"
                         Margin="0,10,0,0"
                         Height="42" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Margin="0,18,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="Description" />
                <TextBox x:Name="DescriptionTextBox"
                         Margin="0,10,0,0"
                         Height="86"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="System prompt" />
                <TextBox x:Name="SystemPromptTextBox"
                         Margin="0,10,0,0"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource GhostButtonStyle}"
                        IsCancel="True"
                        Click="OnCancelClick"
                        Content="Cancel" />
                <Button Width="150"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnCreateClick"
                        Content="Create Project" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
