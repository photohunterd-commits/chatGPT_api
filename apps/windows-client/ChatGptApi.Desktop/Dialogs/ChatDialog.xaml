<Window x:Class="ChatGptApi.Desktop.Dialogs.ChatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Chat"
        Icon="/Assets/AppIcon.png"
        Width="500"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Margin="0"
            Padding="26"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="44"
                            Height="44"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="14"
                            Padding="10">
                        <Path Style="{StaticResource AccentVectorIconStyle}"
                              Data="{StaticResource ChatIconGeometry}" />
                    </Border>

                    <StackPanel Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="New Chat" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Start a chat right away. If no project exists yet, the app can create the first folder automatically." />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,22,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="Title" />
                <TextBox x:Name="TitleTextBox"
                         Margin="0,10,0,0"
                         Height="42"
                         Text="Workspace review" />
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource AccentVectorIconStyle}"
                          Data="{StaticResource ChatIconGeometry}" />
                    <TextBlock Margin="10,0,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="Chats are the main work unit. Projects only help you group them." />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource GhostButtonStyle}"
                        IsCancel="True"
                        Click="OnCancelClick"
                        Content="Cancel" />
                <Button Width="140"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnCreateClick"
                        Content="Create Chat" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
