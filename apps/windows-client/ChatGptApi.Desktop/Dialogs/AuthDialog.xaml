<Window x:Class="ChatGptApi.Desktop.Dialogs.AuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F2EA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#153A29"
                   Text="Sign In" />

        <StackPanel x:Name="NamePanel"
                    Grid.Row="1"
                    Margin="0,18,0,0">
            <TextBlock Text="Name"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <TextBox x:Name="NameTextBox"
                     Margin="0,8,0,0"
                     Height="38"
                     Padding="10,8"
                     Background="White"
                     BorderBrush="#CDA778" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0">
            <TextBlock Text="Email"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <TextBox x:Name="EmailTextBox"
                     Margin="0,8,0,0"
                     Height="38"
                     Padding="10,8"
                     Background="White"
                     BorderBrush="#CDA778" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0">
            <TextBlock Text="Password"
                       FontWeight="SemiBold"
                       Foreground="#153A29" />
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,8,0,0"
                         Height="38"
                         Padding="10,8"
                         Background="White"
                         BorderBrush="#CDA778" />
        </StackPanel>

        <TextBlock x:Name="HintTextBlock"
                   Grid.Row="4"
                   Margin="0,18,0,0"
                   Foreground="#6A6257"
                   Text="Use a private account so projects and chats stay visible only to you." />

        <StackPanel Grid.Row="5"
                    Margin="0,24,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="100"
                    Height="38"
                    Margin="0,0,12,0"
                    Click="OnCancelClick"
                    Content="Cancel" />
            <Button x:Name="SubmitButton"
                    Width="120"
                    Height="38"
                    Background="#153A29"
                    Foreground="White"
                    BorderBrush="#153A29"
                    Click="OnSubmitClick"
                    Content="Sign In" />
        </StackPanel>
    </Grid>
</Window>
