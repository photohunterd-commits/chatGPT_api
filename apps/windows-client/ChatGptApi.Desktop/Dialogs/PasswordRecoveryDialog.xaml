<Window x:Class="ChatGptApi.Desktop.Dialogs.PasswordRecoveryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Recovery"
        Width="560"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Padding="26"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Password Recovery" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="Step 1: send a reset email. Step 2: paste the token from the email and set a new password." />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,22,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="Email" />
                <TextBox x:Name="EmailTextBox"
                         Margin="0,10,0,0"
                         Height="42" />
            </StackPanel>

            <Button Grid.Row="2"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Left"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnSendEmailClick"
                    Content="Send Reset Email" />

            <StackPanel Grid.Row="3"
                        Margin="0,24,0,0">
                <TextBlock FontWeight="SemiBold"
                           Text="Reset token" />
                <TextBox x:Name="TokenTextBox"
                         Margin="0,10,0,0"
                         Height="42" />
                <TextBlock Margin="0,16,0,0"
                           FontWeight="SemiBold"
                           Text="New password" />
                <PasswordBox x:Name="NewPasswordBox"
                             Margin="0,10,0,0"
                             Height="42" />
            </StackPanel>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <TextBlock x:Name="StatusTextBlock"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="If SMTP is configured on the server, the recovery token will arrive by email." />
            </Border>

            <StackPanel Grid.Row="5"
                        Margin="0,24,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="110"
                        Margin="0,0,12,0"
                        Style="{StaticResource GhostButtonStyle}"
                        IsCancel="True"
                        Click="OnCloseClick"
                        Content="Close" />
                <Button Width="150"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnResetPasswordClick"
                        Content="Reset Password" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
