<Window x:Class="ChatGptApi.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ChatGptApi.Desktop.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GPT-5.4 Workspace"
        Width="1480"
        Height="920"
        MinWidth="1240"
        MinHeight="780"
        Loaded="OnLoaded">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="18,18,18,14"
                Padding="18"
                Background="{StaticResource ShellBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="54"
                            Height="54"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="18">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Style="{StaticResource IconTextStyle}"
                                       FontSize="28"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE8A5;" />
                        </Viewbox>
                    </Border>

                    <StackPanel Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="GPT Workspace" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Private projects, focused chats, and one shared AI workspace." />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource ChipBorderStyle}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE77B;" />
                            <TextBlock Margin="8,0,0,0"
                                       MaxWidth="320"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding CurrentUserStatusText}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ChipBorderStyle}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="{Binding BillingBrush}"
                                       FontWeight="SemiBold"
                                       Text="Budget" />
                            <TextBlock Margin="8,0,0,0"
                                       Foreground="{Binding BillingBrush}"
                                       Text="{Binding BillingChipText}" />
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Click="OnSettingsClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconTextStyle}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="&#xE713;" />
                            <TextBlock Margin="8,0,0,0"
                                       Text="Settings" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsSignedOut, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnRegisterClick"
                                Content="Create Account" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnLoginClick"
                                Content="Sign In" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnChangePasswordClick"
                                Content="Password" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnRefreshClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="&#xE72C;" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Click="OnLogoutClick"
                                Content="Log Out" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="312" />
                <ColumnDefinition Width="332" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,14,0"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           FontSize="18"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="&#xE8B7;" />
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="Projects" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    DockPanel.Dock="Right"
                                    IsEnabled="{Binding IsAuthenticated}"
                                    Click="OnCreateProjectClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="&#xE710;" />
                                    <TextBlock Margin="8,0,0,0"
                                               Text="New" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <TextBlock Margin="0,10,0,18"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Spaces for clients, products, or internal initiatives." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Projects}"
                             SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                             SelectionChanged="OnProjectSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ProjectItem}">
                                <Border Margin="0,0,0,10"
                                        Padding="16,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="20" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="38"
                                                Height="38"
                                                Margin="0,0,12,0"
                                                Background="#102A23"
                                                CornerRadius="14">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Text="&#xE8B7;" />
                                            </Viewbox>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Description}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Footer}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,14,0"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           FontSize="18"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="&#xE8BD;" />
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="Chats" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    DockPanel.Dock="Right"
                                    IsEnabled="{Binding IsAuthenticated}"
                                    Click="OnCreateChatClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="&#xE710;" />
                                    <TextBlock Margin="8,0,0,0"
                                               Text="New" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <TextBlock Margin="0,10,0,18"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Focused conversations inside the selected project." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Chats}"
                             SelectedItem="{Binding SelectedChat, Mode=TwoWay}"
                             SelectionChanged="OnChatSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ChatItem}">
                                <Border Margin="0,0,0,10"
                                        Padding="16,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="20" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="#15242E" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="38"
                                                Height="38"
                                                Margin="0,0,12,0"
                                                Background="#122230"
                                                CornerRadius="14">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Style="{StaticResource IconTextStyle}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Text="&#xE8BD;" />
                                            </Viewbox>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       Text="{Binding Model}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding ReasoningEffort}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Footer}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="26"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedChatTitle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Text="{Binding SelectedChatSubtitle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding ProviderKeyStatusText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{Binding BillingBrush}"
                                           Text="{Binding BillingDetailText}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ChipBorderStyle}"
                                    VerticalAlignment="Top">
                                <DockPanel>
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Foreground="{StaticResource WarningBrush}"
                                               Text="&#xE7BA;" />
                                    <TextBlock Margin="8,0,0,0"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Text="{Binding StatusMessage}" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Margin="0,18,0,0"
                            Padding="18"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                                       Text="Write a message. Press Ctrl+Enter to send." />

                            <Grid Grid.Row="1"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         MinHeight="124"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         KeyDown="OnDraftKeyDown"
                                         Text="{Binding DraftMessage, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="1"
                                        Width="138"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Bottom"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        IsEnabled="{Binding IsAuthenticated}"
                                        Click="OnSendMessageClick">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource IconTextStyle}"
                                                   Foreground="White"
                                                   Text="&#xE724;" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Text="Send" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <ScrollViewer Margin="0,18,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding Messages}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:MessageItem}">
                                    <Border MaxWidth="760"
                                            Margin="0,0,0,14"
                                            Padding="18"
                                            HorizontalAlignment="{Binding BubbleAlignment}"
                                            Background="{Binding BubbleBackground}"
                                            BorderBrush="{Binding BubbleBorder}"
                                            BorderThickness="1"
                                            CornerRadius="20">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{Binding Foreground}"
                                                       Text="{Binding Header}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{Binding Foreground}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Content}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       FontSize="12"
                                                       Opacity="0.78"
                                                       Foreground="{Binding Foreground}"
                                                       Text="{Binding Timestamp}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
