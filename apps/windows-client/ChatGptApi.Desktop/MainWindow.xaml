<Window x:Class="ChatGptApi.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ChatGptApi.Desktop.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GPT-5.4 Workspace"
        Icon="Assets/AppIcon.png"
        Width="1480"
        Height="920"
        MinWidth="1240"
        MinHeight="780"
        Loaded="OnLoaded">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="18,18,18,14"
                Padding="18"
                Background="{StaticResource ShellBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="54"
                            Height="54"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="18"
                            Padding="6">
                        <Image Source="Assets/AppIcon.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="GPT Workspace" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Private chats first. Projects are optional folders when you want structure." />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource ChipBorderStyle}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource AccentVectorIconStyle}"
                                  Data="{StaticResource UserIconGeometry}" />
                            <TextBlock Margin="8,0,0,0"
                                       MaxWidth="320"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding CurrentUserStatusText}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ChipBorderStyle}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource AccentVectorIconStyle}"
                                  Data="{StaticResource BudgetIconGeometry}" />
                            <TextBlock Margin="8,0,0,0"
                                       Foreground="{Binding BillingBrush}"
                                       Text="{Binding BillingChipText}" />
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Click="OnSettingsClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource AccentVectorIconStyle}"
                                  Data="{StaticResource SettingsIconGeometry}" />
                            <TextBlock Margin="8,0,0,0"
                                       Text="Settings" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsSignedOut, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnRegisterClick"
                                Content="Create Account" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnLoginClick"
                                Content="Sign In" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnChangePasswordClick"
                                Content="Password" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="OnRefreshClick">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource AccentVectorIconStyle}"
                                      Data="{StaticResource RefreshIconGeometry}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Click="OnLogoutClick"
                                Content="Log Out" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="312" />
                <ColumnDefinition Width="332" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,14,0"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <Path Style="{StaticResource AccentVectorIconStyle}"
                                      Data="{StaticResource ProjectIconGeometry}" />
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="Projects" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    DockPanel.Dock="Right"
                                    IsEnabled="{Binding IsAuthenticated}"
                                    Click="OnCreateProjectClick">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource AccentVectorIconStyle}"
                                          Data="{StaticResource PlusIconGeometry}" />
                                    <TextBlock Margin="8,0,0,0"
                                               Text="New Project" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <TextBlock Margin="0,10,0,18"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Optional folders for grouping chats when you want them organized." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Projects}"
                             x:Name="ProjectsListBox"
                             SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                             PreviewMouseLeftButtonUp="OnProjectsListMouseLeftButtonUp"
                             SelectionChanged="OnProjectSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ProjectItem}">
                                <Border Width="196"
                                        MinHeight="86"
                                        Margin="0,0,0,8"
                                        Padding="12,11">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="18" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="#1B242D" />
                                                    <Setter Property="BorderBrush" Value="#2C6B5B" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34"
                                                Height="34"
                                                Margin="0,0,12,0"
                                                Background="#102A23"
                                                CornerRadius="12"
                                                Padding="7">
                                            <Path Style="{StaticResource AccentVectorIconStyle}"
                                                  Data="{StaticResource ProjectIconGeometry}" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Description}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Footer}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,14,0"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <Path Style="{StaticResource AccentVectorIconStyle}"
                                      Data="{StaticResource ChatIconGeometry}" />
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="Chats" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    DockPanel.Dock="Right"
                                    IsEnabled="{Binding IsAuthenticated}"
                                    Click="OnCreateChatClick">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource AccentVectorIconStyle}"
                                          Data="{StaticResource PlusIconGeometry}" />
                                    <TextBlock Margin="8,0,0,0"
                                               Text="New Chat" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <TextBlock Margin="0,10,0,18"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Standalone chats work too. Start below or keep them inside a project." />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Chats}"
                             x:Name="ChatsListBox"
                             SelectedItem="{Binding SelectedChat, Mode=TwoWay}"
                             PreviewMouseLeftButtonUp="OnChatsListMouseLeftButtonUp"
                             SelectionChanged="OnChatSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ChatItem}">
                                <Border Width="196"
                                        MinHeight="108"
                                        Margin="0,0,0,8"
                                        Padding="12,11">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="18" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="#1A2430" />
                                                    <Setter Property="BorderBrush" Value="#2B6177" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34"
                                                Height="34"
                                                Margin="0,0,12,0"
                                                Background="#122230"
                                                CornerRadius="12"
                                                Padding="7">
                                            <Path Style="{StaticResource AccentVectorIconStyle}"
                                                  Data="{StaticResource ChatIconGeometry}" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Model}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       Text="{Binding ReasoningEffort}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Footer}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="26"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedChatTitle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Text="{Binding SelectedChatSubtitle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding ProviderKeyStatusText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{Binding BillingBrush}"
                                           Text="{Binding BillingDetailText}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ChipBorderStyle}"
                                    VerticalAlignment="Top">
                                <DockPanel>
                                    <Path Style="{StaticResource WarningVectorIconStyle}"
                                          Data="{StaticResource WarningIconGeometry}" />
                                    <TextBlock Margin="8,0,0,0"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Text="{Binding StatusMessage}" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Margin="0,18,0,0"
                            Padding="18"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                                       Text="{Binding ComposerHintText}" />

                            <Grid Grid.Row="1"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         MinHeight="124"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         KeyDown="OnDraftKeyDown"
                                         Text="{Binding DraftMessage, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="1"
                                        Width="138"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Bottom"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        IsEnabled="{Binding IsAuthenticated}"
                                        Click="OnSendMessageClick">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <Path Style="{StaticResource VectorIconStyle}"
                                              Stroke="White"
                                              Data="{StaticResource SendIconGeometry}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Text="{Binding SendButtonText}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <ListBox x:Name="MessagesListBox"
                             Margin="0,18,0,0"
                             Padding="0,0,10,18"
                             ItemsSource="{Binding Messages}"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:MessageItem}">
                                <Grid Margin="0,0,0,14">
                                    <Border MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                            Padding="18"
                                            HorizontalAlignment="{Binding BubbleAlignment}"
                                            Background="{Binding BubbleBackground}"
                                            BorderBrush="{Binding BubbleBorder}"
                                            BorderThickness="1"
                                            CornerRadius="20">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{Binding Foreground}"
                                                       Text="{Binding Header}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{Binding Foreground}"
                                                       TextWrapping="WrapWithOverflow"
                                                       Text="{Binding Content}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       FontSize="12"
                                                       Opacity="0.78"
                                                       Foreground="{Binding Foreground}"
                                                       Text="{Binding Timestamp}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
