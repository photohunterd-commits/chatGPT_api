{
  "name": "codex-project-bridge",
  "displayName": "Codex Project Bridge",
  "description": "A Codex-style chat sidebar for VS Code backed by your private GPT workspace server.",
  "version": "0.5.1",
  "publisher": "photohunterd",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/photohunterd-commits/chatGPT_api.git"
  },
  "files": [
    "dist/**",
    "assets/**",
    "package.json",
    "README.md",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:photohunterd.codexBridge.chat",
    "onCommand:codexBridge.register",
    "onCommand:codexBridge.login",
    "onCommand:codexBridge.logout",
    "onCommand:codexBridge.configureProviderKey",
    "onCommand:codexBridge.refresh",
    "onCommand:codexBridge.newChat",
    "onCommand:codexBridge.sendSelection",
    "onCommand:codexBridge.openChat"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap",
    "package": "npm run build && vsce package --no-yarn --no-dependencies"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "photohunterd.codexBridge.chat",
        "fullName": "GPT Workspace",
        "name": "gpt54",
        "description": "Private GPT workspace on your server",
        "isSticky": true,
        "commands": [
          {
            "name": "help",
            "description": "Show setup and usage help."
          },
          {
            "name": "login",
            "description": "Sign in to your GPT Workspace account."
          },
          {
            "name": "register",
            "description": "Create a new GPT Workspace account."
          },
          {
            "name": "key",
            "description": "Save or replace your personal model API key."
          },
          {
            "name": "logout",
            "description": "Sign out from GPT Workspace."
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "codexBridge.openChat",
        "title": "Codex Bridge: Open Chat"
      },
      {
        "command": "codexBridge.register",
        "title": "Codex Bridge: Register"
      },
      {
        "command": "codexBridge.login",
        "title": "Codex Bridge: Sign In"
      },
      {
        "command": "codexBridge.logout",
        "title": "Codex Bridge: Log Out"
      },
      {
        "command": "codexBridge.configureProviderKey",
        "title": "Codex Bridge: Configure Model API Key"
      },
      {
        "command": "codexBridge.refresh",
        "title": "Codex Bridge: Refresh"
      },
      {
        "command": "codexBridge.newChat",
        "title": "Codex Bridge: New Chat"
      },
      {
        "command": "codexBridge.sendSelection",
        "title": "Codex Bridge: Send Selection to Chat"
      }
    ],
    "configuration": {
      "title": "Codex Project Bridge",
      "properties": {
        "codexBridge.userEmail": {
          "type": "string",
          "default": "",
          "description": "Last signed-in email for the Codex Bridge backend."
        },
        "codexBridge.defaultProjectId": {
          "type": "string",
          "default": "",
          "description": "Internal id of the hidden Codex project."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.1",
    "axios": "^1.12.2",
    "esbuild": "^0.25.11",
    "typescript": "^5.9.3"
  }
}
