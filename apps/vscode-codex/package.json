{
  "name": "codex-project-bridge",
  "displayName": "GPT54 Codex",
  "description": "A GPT54 Codex chat view in the VS Code sidebar backed by your private GPT workspace server.",
  "version": "0.6.5",
  "publisher": "photohunterd",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/photohunterd-commits/chatGPT_api.git"
  },
  "files": [
    "dist/**",
    "assets/**",
    "package.json",
    "README.md",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:photohunterd.gpt54Codex.sidebar",
    "onView:photohunterd.gpt54Codex.chat",
    "onCommand:codexBridge.register",
    "onCommand:codexBridge.login",
    "onCommand:codexBridge.logout",
    "onCommand:codexBridge.configureProviderKey",
    "onCommand:codexBridge.refresh",
    "onCommand:codexBridge.newChat",
    "onCommand:codexBridge.sendSelection",
    "onCommand:codexBridge.openChat"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap",
    "package": "npm run build && vsce package --no-yarn --no-dependencies"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "photohunterd.gpt54CodexSidebar",
          "title": "GPT54",
          "icon": "assets/codex-bridge.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "photohunterd.gpt54Codex",
          "title": "GPT54",
          "icon": "assets/codex-bridge.svg"
        }
      ]
    },
    "views": {
      "photohunterd.gpt54CodexSidebar": [
        {
          "type": "webview",
          "id": "photohunterd.gpt54Codex.sidebar",
          "name": "GPT54 Codex"
        }
      ],
      "photohunterd.gpt54Codex": [
        {
          "type": "webview",
          "id": "photohunterd.gpt54Codex.chat",
          "name": "GPT54 Codex"
        }
      ]
    },
    "commands": [
      {
        "command": "codexBridge.openChat",
        "title": "GPT54 Codex: Open Chat"
      },
      {
        "command": "codexBridge.register",
        "title": "GPT54 Codex: Open Sign In"
      },
      {
        "command": "codexBridge.login",
        "title": "GPT54 Codex: Open Sign In"
      },
      {
        "command": "codexBridge.logout",
        "title": "GPT54 Codex: Log Out"
      },
      {
        "command": "codexBridge.configureProviderKey",
        "title": "GPT54 Codex: Open API Key"
      },
      {
        "command": "codexBridge.refresh",
        "title": "GPT54 Codex: Refresh"
      },
      {
        "command": "codexBridge.newChat",
        "title": "GPT54 Codex: New Chat"
      },
      {
        "command": "codexBridge.sendSelection",
        "title": "GPT54 Codex: Send Selection"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codexBridge.newChat",
          "when": "view == photohunterd.gpt54Codex.sidebar || view == photohunterd.gpt54Codex.chat",
          "group": "navigation@1"
        },
        {
          "command": "codexBridge.configureProviderKey",
          "when": "view == photohunterd.gpt54Codex.sidebar || view == photohunterd.gpt54Codex.chat",
          "group": "navigation@2"
        },
        {
          "command": "codexBridge.refresh",
          "when": "view == photohunterd.gpt54Codex.sidebar || view == photohunterd.gpt54Codex.chat",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Codex Project Bridge",
      "properties": {
        "codexBridge.userEmail": {
          "type": "string",
          "default": "",
          "description": "Last signed-in email for the Codex Bridge backend."
        },
        "codexBridge.defaultProjectId": {
          "type": "string",
          "default": "",
          "description": "Internal id of the hidden Codex project."
        },
        "codexBridge.defaultChatId": {
          "type": "string",
          "default": "",
          "description": "Internal id of the active GPT54 Codex chat."
        },
        "codexBridge.selectedModel": {
          "type": "string",
          "default": "gpt-5.3-codex",
          "description": "Default GPT54 Codex model for the next new chat."
        },
        "codexBridge.selectedReasoningEffort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "description": "Reasoning depth for the next new GPT54 Codex chat."
        },
        "codexBridge.openOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Open the GPT54 Codex sidebar automatically after install or update."
        }
      }
    }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.8.1",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.1",
    "axios": "^1.12.2",
    "esbuild": "^0.25.11",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "typescript": "^5.9.3"
  }
}
